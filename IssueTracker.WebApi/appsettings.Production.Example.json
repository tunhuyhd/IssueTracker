{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-prod-db;Database=IssueTrackerProd;Username=appuser;Password=***"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileStorage": {
    "DefaultProvider": "cloudinary",
    "Cloudinary": {
      "CloudName": "your-cloud-name",
      "ApiKey": "your-api-key",
      "ApiSecret": "your-api-secret",
      "RootFolder": "issuetracker",
      "UseSecureUrl": true
    }
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": "587",
    "SmtpUsername": "your-production-email@gmail.com",
    "SmtpPassword": "your-app-password",
    "FromEmail": "your-production-email@gmail.com",
    "FromName": "IssueTracker System"
  },
  "AppSettings": {
    "FrontendUrl": "https://your-production-domain.com"
  }
}